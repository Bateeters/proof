<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="10.0.9" />
    <!-- Pin transitive Microsoft.OpenApi past 2.0.0, which has a known high-severity
         advisory (GHSA-v5pm-xwqc-g5wc); Microsoft.AspNetCore.OpenApi 10.0.9 hasn't
         picked up a fix yet. Remove this override once it does. -->
    <PackageReference Include="Microsoft.OpenApi" Version="2.10.0" />
  </ItemGroup>

</Project>
